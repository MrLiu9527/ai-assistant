# Copy to the server as /opt/ai-assistant/.env (do not commit real secrets)

DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/DBNAME
DATABASE_SYNC_URL=postgresql+psycopg2://USER:PASS@HOST:5432/DBNAME

APP_ENV=production
DEBUG=false

# Optional: set to 1 once on first deploy if tables are empty
INIT_DB=0

DASHSCOPE_API_KEY=
OPENAI_API_KEY=

UVICORN_WORKERS=2
